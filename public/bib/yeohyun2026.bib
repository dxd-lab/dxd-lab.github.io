author = {Jung, Yeohyun and Nam, Sooyohn and An, Junhyun and Hong, Hwajung},
title = {Your Call—Keep or Wrap: Examining the Impact of Self-regulatory Intervention on Short-form Video Consumption Behavior},
year = {2026},
